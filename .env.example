# ─── OpenAI ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-REEMPLAZA_CON_TU_CLAVE
# gpt-4.1-mini = más reciente y rápido. Alternativas: gpt-4.1-nano (máx
# velocidad, menos matiz) | gpt-4.1 (más calidad, algo más lento)
OPENAI_MODEL=gpt-4.1-mini
# Tope de tokens de salida por respuesta (acota el coste / anti-abuso)
OPENAI_MAX_OUTPUT_TOKENS=800
# Trozos que recupera file_search (menos = más rápido, menos contexto)
OPENAI_FILE_SEARCH_MAX_RESULTS=10
# Vector store general de fallback (opcional si usas los VS por módulo)
OPENAI_VECTOR_STORE_ID=

# ─── Supabase (el servidor NO arranca si falta alguna) ───────────────────
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_ANON_KEY=eyJ...la-anon-key-publica
SUPABASE_SERVICE_ROLE_KEY=eyJ...la-service-role-key-SECRETA

# ─── Servidor ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8787
# Orígenes permitidos para CORS y para embeber el widget en Kajabi (iframe)
ALLOWED_ORIGINS=http://localhost:8787,https://TU-SUBDOMINIO.mykajabi.com

# ─── Vector Stores por módulo (opcional) ─────────────────────────────────
VS_PRIMEROS_PASOS=
VS_CONOCER_LA_MENTE=
VS_HIPNOSIS=
VS_APEGO=
VS_INVITADOS_ESPECIALES=
VS_SENSUALIDAD=
VS_GEISHAS=
VS_ESTRATEGIA=
VS_DETECTAR_HOMBRE=
VS_NEUROPSICOLOGIA=
